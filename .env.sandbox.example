# PayBridge sandbox validation — copy to .env.sandbox and fill in
#
# Usage:
#   cp .env.sandbox.example .env.sandbox
#   # edit values
#   set -a && source .env.sandbox && set +a
#   npx paybridge test --all
#
# .env.sandbox is gitignored — do not commit.

# Already validated (fill from your previous tests)
STRIPE_API_KEY=sk_test_replace_me

PAYSTACK_API_KEY=sk_test_replace_me
PAYSTACK_TEST_CURRENCY=ZAR

PAYFAST_MERCHANT_ID=10045563
PAYFAST_MERCHANT_KEY=ftt0qv8wpo0ha
PAYFAST_PASSPHRASE=whatsauction

# Instant signup (~2-5 min each)
# https://dashboard.flutterwave.com/signup
FLUTTERWAVE_API_KEY=FLWSECK_TEST-replace_me

# https://dashboard.razorpay.com/signup
RAZORPAY_API_KEY=rzp_test_replace_me
RAZORPAY_SECRET_KEY=replace_me

# https://my.mollie.com/dashboard/signup
MOLLIE_API_KEY=test_replace_me

# https://developer.squareup.com/apps  → create app → Sandbox tab
SQUARE_API_KEY=EAAA_replace_me
SQUARE_LOCATION_ID=L_replace_me

# https://onboarding.yoco.com/sandbox
